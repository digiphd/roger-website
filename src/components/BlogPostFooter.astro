---
import { SITE_URL, SOCIAL } from "../consts";

interface Props {
  title: string;
  tags: string[];
  slug: string;
  prevPost?: { id: string; title: string } | null;
  nextPost?: { id: string; title: string } | null;
}

const { title, tags, slug, prevPost, nextPost } = Astro.props;

const postUrl = `${SITE_URL}/blog/${slug}`;
const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(postUrl);

const shareLinks = [
  { label: "X", href: `https://x.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}` },
  { label: "LinkedIn", href: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}` },
  { label: "WhatsApp", href: `https://wa.me/?text=${encodedTitle}%20${encodedUrl}` },
  { label: "Telegram", href: `https://t.me/share/url?url=${encodedUrl}&text=${encodedTitle}` },
  { label: "Email", href: `mailto:?subject=${encodedTitle}&body=${encodedUrl}` },
];
---

<!-- Subscribe -->
<div class="mt-12 p-6 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-raised)]">
  <p class="font-medium text-[var(--color-text-primary)] mb-1">
    New posts, shipping stories, and nerdy links straight to your inbox.
  </p>
  <form
    action="https://buttondown.com/api/emails/embed-subscribe/roger_creator"
    method="post"
    target="popupwindow"
    class="flex flex-col sm:flex-row gap-3 mt-4"
  >
    <input
      type="email"
      name="email"
      placeholder="you@example.com"
      required
      class="flex-1 px-4 py-2.5 rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-text-primary)] placeholder:text-[var(--color-text-muted)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]"
    />
    <button
      type="submit"
      class="px-6 py-2.5 rounded-md bg-[var(--color-accent)] text-white font-medium text-sm hover:bg-[var(--color-accent-light)] transition-colors whitespace-nowrap"
    >
      Subscribe
    </button>
  </form>
  <p class="text-xs text-[var(--color-text-muted)] mt-2">
    2&times; per month, pure signal, zero fluff.
  </p>
</div>

<!-- Divider -->
<hr class="my-8 border-[var(--color-border)]" />

<!-- Tags -->
{tags.length > 0 && (
  <div class="flex flex-wrap gap-2 mb-6">
    {tags.map((tag) => (
      <a
        href={`/blog?tag=${tag}`}
        class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors"
      >
        #{tag}
      </a>
    ))}
  </div>
)}

<!-- Share -->
<div class="mb-8">
  <p class="text-sm italic text-[var(--color-text-muted)] mb-3">Share this post on:</p>
  <div class="flex items-center gap-4">
    {shareLinks.map((link) => (
      <a
        href={link.href}
        target="_blank"
        rel="noopener noreferrer"
        class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors"
        aria-label={`Share on ${link.label}`}
      >
        {link.label === "X" && (
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path>
          </svg>
        )}
        {link.label === "LinkedIn" && (
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
          </svg>
        )}
        {link.label === "WhatsApp" && (
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path>
          </svg>
        )}
        {link.label === "Telegram" && (
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M11.944 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0a12 12 0 00-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 01.171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"></path>
          </svg>
        )}
        {link.label === "Email" && (
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <rect x="2" y="4" width="20" height="16" rx="2" />
            <path d="M22 4L12 13 2 4" />
          </svg>
        )}
      </a>
    ))}

    <!-- Back to Top -->
    <a
      href="#"
      class="ml-auto text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors flex items-center gap-1"
      onclick="window.scrollTo({top:0,behavior:'smooth'});return false;"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
      </svg>
      Back to Top
    </a>
  </div>
</div>

<!-- Prev / Next -->
<hr class="mb-6 border-[var(--color-border)]" />
<nav class="flex justify-between items-start gap-4 mb-8">
  {prevPost ? (
    <a href={`/blog/${prevPost.id}`} class="group flex items-start gap-2 max-w-[45%]">
      <span class="text-[var(--color-text-muted)] group-hover:text-[var(--color-accent)] transition-colors mt-0.5">&larr;</span>
      <div>
        <span class="text-xs text-[var(--color-text-muted)] uppercase tracking-wide">Previous Post</span>
        <p class="text-sm text-[var(--color-accent)] group-hover:text-[var(--color-accent-light)] transition-colors font-medium leading-tight mt-0.5">
          {prevPost.title}
        </p>
      </div>
    </a>
  ) : <div />}
  {nextPost ? (
    <a href={`/blog/${nextPost.id}`} class="group flex items-start gap-2 max-w-[45%] text-right ml-auto">
      <div>
        <span class="text-xs text-[var(--color-text-muted)] uppercase tracking-wide">Next Post</span>
        <p class="text-sm text-[var(--color-accent)] group-hover:text-[var(--color-accent-light)] transition-colors font-medium leading-tight mt-0.5">
          {nextPost.title}
        </p>
      </div>
      <span class="text-[var(--color-text-muted)] group-hover:text-[var(--color-accent)] transition-colors mt-0.5">&rarr;</span>
    </a>
  ) : <div />}
</nav>

<!-- License -->
<div class="text-xs text-[var(--color-text-muted)] pt-4 border-t border-[var(--color-border)]">
  Steal this post &rarr; CC BY 4.0 &middot; Code MIT
</div>
