---
import { SOCIAL } from "../consts";
---

<footer class="border-t border-[var(--color-border)] py-8 mt-auto">
  <div
    class="max-w-3xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4"
  >
    <p class="text-sm text-[var(--color-text-muted)]">
      &copy; {new Date().getFullYear()} Roger Chappel
    </p>
    <div class="flex items-center gap-5">
      <a
        href={SOCIAL.twitter}
        target="_blank"
        rel="noopener noreferrer"
        class="text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors"
        aria-label="X / Twitter"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
          ></path>
        </svg>
      </a>
      <a
        href={SOCIAL.github}
        target="_blank"
        rel="noopener noreferrer"
        class="text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors"
        aria-label="GitHub"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
          ></path>
        </svg>
      </a>
      <a
        href={SOCIAL.axislabs}
        target="_blank"
        rel="noopener noreferrer"
        class="text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors text-xs font-medium"
      >
        Axislabs
      </a>
      <a
        href="/rss.xml"
        class="text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors"
        aria-label="RSS Feed"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M6.18 15.64a2.18 2.18 0 010 4.36 2.18 2.18 0 010-4.36M4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44m0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93V10.1z"
          ></path>
        </svg>
      </a>
    </div>
  </div>
</footer>
