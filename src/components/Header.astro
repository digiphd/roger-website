---
import { SITE_TITLE } from "../consts";
import SearchModal from "./SearchModal.astro";

const navLinks = [
  { href: "/blog", label: "Blog" },
  { href: "/about", label: "About" },
];

const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-surface)]/80 backdrop-blur-lg"
>
  <nav class="max-w-3xl mx-auto px-6 h-16 flex items-center justify-between">
    <a
      href="/"
      class="text-xl font-bold tracking-tight transition-colors group"
    >
      <span class="text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors">Roger</span><span class="text-[var(--color-accent)]"> Chappel</span>
    </a>
    <div class="flex items-center gap-6">
      <ul class="flex items-center gap-6">
        {
          navLinks.map(({ href, label }) => {
            const isActive = currentPath === href || (href !== "/" && currentPath.startsWith(href));
            return (
              <li>
                <a
                  href={href}
                  class:list={[
                    "nav-link relative text-sm font-medium pb-1 transition-colors",
                    isActive
                      ? "text-[var(--color-accent)] nav-link-active"
                      : "text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]",
                  ]}
                >
                  {label}
                </a>
              </li>
            );
          })
        }
      </ul>
      <button
        id="search-trigger"
        type="button"
        aria-label="Search (⌘K)"
        class="p-2 rounded-lg text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-surface-raised)] transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <circle cx="11" cy="11" r="8" />
          <path d="M21 21l-4.35-4.35" />
        </svg>
      </button>
      <button
        id="theme-toggle"
        type="button"
        aria-label="Toggle theme"
        class="p-2 rounded-lg text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-surface-raised)] transition-colors"
      >
        <!-- Sun icon (light mode active) -->
        <svg id="icon-sun" class="w-4 h-4 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="5" />
          <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
        </svg>
        <!-- Moon icon (dark mode active) -->
        <svg id="icon-moon" class="w-4 h-4 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
        </svg>
        <!-- System icon (auto mode active) -->
        <svg id="icon-system" class="w-4 h-4 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <rect x="2" y="3" width="20" height="14" rx="2" ry="2" />
          <line x1="8" y1="21" x2="16" y2="21" />
          <line x1="12" y1="17" x2="12" y2="21" />
        </svg>
      </button>
    </div>
  </nav>
</header>

<SearchModal />

<script>
  type Theme = 'light' | 'dark' | 'system';

  function getSystemDark(): boolean {
    return window.matchMedia('(prefers-color-scheme: dark)').matches;
  }

  function applyTheme(theme: Theme) {
    const isDark = theme === 'dark' || (theme === 'system' && getSystemDark());
    document.documentElement.classList.toggle('dark', isDark);

    document.getElementById('icon-sun')!.classList.toggle('hidden', theme !== 'dark');
    document.getElementById('icon-moon')!.classList.toggle('hidden', theme !== 'light');
    document.getElementById('icon-system')!.classList.toggle('hidden', theme !== 'system');
  }

  // Cycle: light → dark → system
  const cycle: Theme[] = ['light', 'dark', 'system'];

  function getStored(): Theme {
    const s = localStorage.getItem('theme');
    if (s === 'light' || s === 'dark') return s;
    return 'system';
  }

  // Init
  applyTheme(getStored());

  // Listen for system preference changes when in system mode
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
    if (getStored() === 'system') applyTheme('system');
  });

  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const current = getStored();
    const next = cycle[(cycle.indexOf(current) + 1) % cycle.length];
    if (next === 'system') {
      localStorage.removeItem('theme');
    } else {
      localStorage.setItem('theme', next);
    }
    applyTheme(next);
  });
</script>
