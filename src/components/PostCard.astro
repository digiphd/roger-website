---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  readingTime: string;
}

const { title, description, pubDate, slug, readingTime } = Astro.props;

const formattedDate = pubDate.toLocaleDateString("en-AU", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<a href={`/blog/${slug}`} class="group block">
  <article
    class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-surface-overlay)] hover:bg-[var(--color-surface-raised)] transition-all duration-200"
  >
    <div class="flex items-center gap-3 text-sm text-[var(--color-text-muted)] mb-3">
      <time datetime={pubDate.toISOString()}>{formattedDate}</time>
      <span class="text-[var(--color-surface-overlay)]">&middot;</span>
      <span>{readingTime}</span>
    </div>
    <h3
      class="text-xl font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent-light)] transition-colors mb-2"
    >
      {title}
    </h3>
    <p class="text-[var(--color-text-secondary)] leading-relaxed">{description}</p>
  </article>
</a>
