---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  readingTime: string;
}

const { title, description, pubDate, slug, readingTime } = Astro.props;

const formattedDate = pubDate.toLocaleDateString("en-AU", {
  day: "numeric",
  month: "short",
  year: "numeric",
});

const ogImage = `/og/${slug}.png`;
---

<a
  href={`/blog/${slug}`}
  class="group block rounded-lg px-4 py-4 -mx-4 hover:bg-[var(--color-surface-raised)] transition-colors"
>
  <img
    src={ogImage}
    alt={title}
    class="w-full rounded-md border border-[var(--color-border)] mb-3"
    loading="lazy"
  />
  <div class="flex items-baseline justify-between gap-4">
    <h3 class="text-lg font-medium text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors">
      {title}
    </h3>
    <span class="text-xs text-[var(--color-text-muted)] whitespace-nowrap shrink-0">
      {formattedDate}
    </span>
  </div>
  <p class="mt-1 text-base text-[var(--color-text-secondary)] line-clamp-2">
    {description}
  </p>
  <span class="mt-1.5 inline-block text-xs text-[var(--color-text-muted)]">
    {readingTime}
  </span>
</a>
