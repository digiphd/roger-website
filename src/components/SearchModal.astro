<div
  id="search-modal"
  class="fixed inset-0 z-[100] hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Search blog posts"
>
  <!-- Backdrop -->
  <div id="search-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

  <!-- Modal -->
  <div class="relative flex items-start justify-center pt-[20vh] px-4">
    <div class="w-full max-w-lg bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl shadow-2xl overflow-hidden">
      <!-- Input -->
      <div class="flex items-center gap-3 px-4 border-b border-[var(--color-border)]">
        <svg class="w-4 h-4 text-[var(--color-text-muted)] shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <circle cx="11" cy="11" r="8" />
          <path d="M21 21l-4.35-4.35" />
        </svg>
        <input
          id="search-input"
          type="text"
          placeholder="Search posts..."
          autocomplete="off"
          class="w-full py-3 bg-transparent text-[var(--color-text-primary)] placeholder:text-[var(--color-text-muted)] outline-none text-sm"
        />
        <kbd class="hidden sm:inline-block text-[10px] text-[var(--color-text-muted)] border border-[var(--color-border)] rounded px-1.5 py-0.5 shrink-0">ESC</kbd>
      </div>

      <!-- Results -->
      <div id="search-results" class="max-h-[40vh] overflow-y-auto">
        <div id="search-empty" class="px-4 py-8 text-center text-sm text-[var(--color-text-muted)]">
          Type to search blog posts
        </div>
        <ul id="search-list" class="py-2 hidden"></ul>
        <div id="search-no-results" class="px-4 py-8 text-center text-sm text-[var(--color-text-muted)] hidden">
          No posts found
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  interface SearchPost {
    title: string;
    description: string;
    slug: string;
    pubDate: string;
  }

  let posts: SearchPost[] = [];
  let loaded = false;

  async function loadSearchData() {
    if (loaded) return;
    const res = await fetch('/search.json');
    posts = await res.json();
    loaded = true;
  }

  function getModal() { return document.getElementById('search-modal')!; }
  function getInput() { return document.getElementById('search-input') as HTMLInputElement; }
  function getList() { return document.getElementById('search-list')!; }
  function getEmpty() { return document.getElementById('search-empty')!; }
  function getNoResults() { return document.getElementById('search-no-results')!; }

  function openSearch() {
    const modal = getModal();
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    getInput().value = '';
    getInput().focus();
    showEmpty();
    loadSearchData();
  }

  function closeSearch() {
    const modal = getModal();
    modal.classList.add('hidden');
    document.body.style.overflow = '';
  }

  function showEmpty() {
    getList().classList.add('hidden');
    getNoResults().classList.add('hidden');
    getEmpty().classList.remove('hidden');
  }

  function renderResults(query: string) {
    const list = getList();
    const empty = getEmpty();
    const noResults = getNoResults();

    if (!query.trim()) {
      showEmpty();
      return;
    }

    const q = query.toLowerCase();
    const matches = posts.filter(
      (p) => p.title.toLowerCase().includes(q) || p.description.toLowerCase().includes(q)
    );

    empty.classList.add('hidden');

    if (matches.length === 0) {
      list.classList.add('hidden');
      noResults.classList.remove('hidden');
      return;
    }

    noResults.classList.add('hidden');
    list.classList.remove('hidden');
    list.innerHTML = matches
      .map(
        (p) => `<li>
          <a href="/blog/${p.slug}" class="flex flex-col gap-0.5 px-4 py-2.5 hover:bg-[var(--color-surface-raised)] transition-colors">
            <span class="text-sm font-medium text-[var(--color-text-primary)]">${escapeHtml(p.title)}</span>
            <span class="text-xs text-[var(--color-text-secondary)] line-clamp-1">${escapeHtml(p.description)}</span>
          </a>
        </li>`
      )
      .join('');
  }

  function escapeHtml(str: string): string {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  // Event listeners
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      const modal = getModal();
      if (modal.classList.contains('hidden')) {
        openSearch();
      } else {
        closeSearch();
      }
    }
    if (e.key === 'Escape') {
      closeSearch();
    }
  });

  document.getElementById('search-backdrop')?.addEventListener('click', closeSearch);

  getInput().addEventListener('input', (e) => {
    renderResults((e.target as HTMLInputElement).value);
  });

  // Allow opening from external trigger
  document.getElementById('search-trigger')?.addEventListener('click', openSearch);
</script>
