---
/**
 * A numbered step in a workflow or process.
 * Use multiple Steps in sequence to build a visual flow.
 */
interface Props {
  number: number;
  title: string;
}

const { number, title } = Astro.props;
---

<div class="my-6 flex gap-4 not-prose">
  <div class="flex-shrink-0 w-10 h-10 rounded-full bg-[var(--color-accent)] text-white flex items-center justify-center font-bold text-lg">
    {number}
  </div>
  <div class="flex-1 pt-1">
    <p class="font-semibold text-[var(--color-text-primary)] text-lg">{title}</p>
    <div class="text-[var(--color-text-secondary)] mt-1 text-base leading-relaxed [&>p]:mb-2 [&>p:last-child]:mb-0">
      <slot />
    </div>
  </div>
</div>
