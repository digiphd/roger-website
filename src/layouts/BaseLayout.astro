---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL, AUTHOR, SOCIAL_PROFILES } from "../consts";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  article?: boolean;
  pubDate?: Date;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = SITE_DESCRIPTION,
  ogImage = AUTHOR.photo,
  article = false,
  pubDate,
  jsonLd,
} = Astro.props;

const pageTitle = title ? `${title} — ${SITE_TITLE}` : `${SITE_TITLE} — Builder, Engineer, Founder`;
const canonicalUrl = new URL(Astro.url.pathname, SITE_URL);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE_TITLE}
      href={`${SITE_URL}/rss.xml`}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&family=Space+Grotesk:wght@700&display=swap"
      rel="stylesheet"
    />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={AUTHOR.name} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content={article ? "article" : "website"} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, SITE_URL)} />
    <meta property="og:site_name" content={SITE_TITLE} />
    <meta property="og:locale" content="en_AU" />
    {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={AUTHOR.handle} />
    <meta name="twitter:creator" content={AUTHOR.handle} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, SITE_URL)} />

    <!-- JSON-LD structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd ?? {
      "@context": "https://schema.org",
      "@type": article ? "BlogPosting" : "WebSite",
      "name": pageTitle,
      "description": description,
      "url": canonicalUrl.toString(),
      ...(article ? {
        "author": {
          "@type": "Person",
          "name": AUTHOR.name,
          "url": SITE_URL,
          "jobTitle": AUTHOR.jobTitle,
          "image": new URL(AUTHOR.photo, SITE_URL).toString(),
          "worksFor": {
            "@type": "Organization",
            ...AUTHOR.organization,
          },
          "sameAs": [...SOCIAL_PROFILES],
        },
        ...(pubDate ? { "datePublished": pubDate.toISOString() } : {}),
      } : {
        "author": {
          "@type": "Person",
          "name": AUTHOR.name,
          "url": SITE_URL,
          "jobTitle": AUTHOR.jobTitle,
          "worksFor": {
            "@type": "Organization",
            ...AUTHOR.organization,
          },
          "sameAs": [...SOCIAL_PROFILES],
        },
      }),
    })} />
    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      (function() {
        const s = localStorage.getItem('theme');
        if (s === 'dark' || (!s && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body
    class="min-h-screen flex flex-col bg-[var(--color-surface)] text-[var(--color-text-primary)]"
  >
    <Header />
    <main class="flex-1 w-full max-w-3xl mx-auto px-6 py-12">
      <slot />
    </main>
    <Footer />
  </body>
</html>
