---
import BaseLayout from "../layouts/BaseLayout.astro";
import { AUTHOR, SOCIAL, GITHUB_USERNAME, NEWSLETTER_ID } from "../consts";
---

<BaseLayout title="About" description={`${AUTHOR.name} — ${AUTHOR.aboutDescription}`}>
  <section class="py-8">
    <div class="flex flex-col md:flex-row gap-8 md:gap-10 items-start">
      <!-- Photo -->
      <div class="w-full md:w-[280px] lg:w-[320px] shrink-0">
        <img
          src="/images/roger-setup.jpg"
          alt="Roger at his desk"
          class="w-full rounded-xl border border-[var(--color-border)] object-cover"
          loading="eager"
          width="600"
          height="800"
        />
      </div>

      <!-- Intro text -->
      <div class="flex-1 min-w-0">
        <h1 class="text-3xl font-bold">About me</h1>
        <p class="text-lg text-[var(--color-text-secondary)] mt-2">Builder. Engineer. Founder.</p>

        <div class="prose prose-lg max-w-none mt-6">
          {AUTHOR.aboutIntro.slice(0, 2).map((paragraph) => (
            <p set:html={paragraph} />
          ))}
        </div>
      </div>
    </div>

    <!-- Remaining intro + topics -->
    <div class="prose prose-lg max-w-none mt-8">
      {AUTHOR.aboutIntro.slice(2).map((paragraph) => (
        <p set:html={paragraph} />
      ))}
      <h2>What I write about</h2>
      <ul>
        {AUTHOR.writesAbout.map((topic) => (
          <li>{topic}</li>
        ))}
      </ul>
    </div>

    <!-- GitHub Activity -->
    <div class="mt-12">
      <h2 class="text-2xl font-semibold text-[var(--color-accent)] mb-4">GitHub Activity</h2>
      <div class="rounded-xl bg-[var(--color-surface-raised)] border border-[var(--color-border)] p-6 overflow-x-auto">
        <img
          src={`https://ghchart.rshah.org/3b82f6/${GITHUB_USERNAME}`}
          alt={`${AUTHOR.name}'s GitHub contribution chart`}
          class="w-full dark:invert-0"
          loading="lazy"
        />
      </div>
      <div class="mt-4 grid grid-cols-2 sm:grid-cols-4 gap-3" id="gh-stats">
        <!-- Populated by script below -->
      </div>
    </div>

    <!-- GitHub CTA -->
    <div class="mt-8 rounded-xl bg-[var(--color-surface-raised)] border border-[var(--color-border)] p-6 sm:p-8 flex flex-col sm:flex-row items-center gap-4 sm:gap-6">
      <div class="flex-1">
        <h3 class="text-lg font-semibold">Building in public on GitHub</h3>
        <p class="mt-1 text-base text-[var(--color-text-secondary)]">
          All my projects are open or shipping soon. Follow along, star repos, or contribute.
        </p>
      </div>
      <a
        href={SOCIAL.github}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-[var(--color-text-primary)] text-[var(--color-surface)] text-base font-medium hover:opacity-90 transition-opacity shrink-0"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"></path>
        </svg>
        Follow on GitHub
      </a>
    </div>

    <!-- Newsletter -->
    <div class="mt-12 rounded-xl bg-[var(--color-surface-raised)] border border-[var(--color-border)] p-6 sm:p-8">
      <h2 class="text-xl font-semibold">Stay in the loop ✉️</h2>
      <p class="mt-2 text-base text-[var(--color-text-secondary)]">
        I write about building AI products, shipping SaaS, and the founder journey. No spam, unsubscribe anytime.
      </p>
      <form
        action={`https://buttondown.com/api/emails/embed-subscribe/${NEWSLETTER_ID}`}
        method="post"
        target="popupwindow"
        class="mt-4 flex flex-col sm:flex-row gap-3"
      >
        <input
          type="email"
          name="email"
          placeholder="you@example.com"
          required
          class="flex-1 px-4 py-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-base text-[var(--color-text-primary)] placeholder-[var(--color-text-muted)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]/30 focus:border-[var(--color-accent)]"
        />
        <button
          type="submit"
          class="px-6 py-3 rounded-lg bg-[var(--color-accent)] text-white text-base font-medium hover:bg-[var(--color-accent-dark)] transition-colors"
        >
          Subscribe
        </button>
      </form>
    </div>

    <!-- Say hi -->
    <div class="mt-12 prose prose-lg max-w-none">
      <h2>Say hi</h2>
      <p>
        Find me on <a href={SOCIAL.twitter} target="_blank" rel="noopener noreferrer">X</a>,
        <a href={SOCIAL.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>, or
        <a href={SOCIAL.tiktok} target="_blank" rel="noopener noreferrer">TikTok</a>.
        Always happy to chat with other builders.
      </p>
    </div>
  </section>

  <script define:vars={{ GITHUB_USERNAME }}>
    async function loadGitHubStats() {
      try {
        const res = await fetch(`https://api.github.com/users/${GITHUB_USERNAME}`);
        if (!res.ok) return;
        const data = await res.json();
        const container = document.getElementById('gh-stats');
        if (!container) return;

        const stats = [
          { label: 'Public repos', value: data.public_repos },
          { label: 'Followers', value: data.followers },
          { label: 'Following', value: data.following },
          { label: 'Member since', value: new Date(data.created_at).getFullYear() },
        ];

        container.innerHTML = stats.map(s => `
          <div class="rounded-lg bg-[var(--color-surface-overlay)] border border-[var(--color-border)] p-3 text-center">
            <div class="text-xl font-bold text-[var(--color-accent)]">${s.value}</div>
            <div class="text-xs text-[var(--color-text-muted)] mt-1">${s.label}</div>
          </div>
        `).join('');
      } catch {}
    }
    loadGitHubStats();
  </script>
</BaseLayout>
