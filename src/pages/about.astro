---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SOCIAL } from "../consts";
---

<BaseLayout title="About" description="Roger Chappel — technical founder, full-stack engineer, and AI product builder based in Australia.">
  <section class="py-8">
    <div class="flex items-center gap-6 mb-8">
      <img
        src="/roger.jpg"
        alt="Roger Chappel"
        class="w-20 h-20 rounded-full object-cover ring-2 ring-[var(--color-border)]"
      />
      <div>
        <h1 class="text-3xl font-bold">About me</h1>
        <p class="text-[var(--color-text-secondary)] mt-1">Builder. Engineer. Founder.</p>
      </div>
    </div>
    <div class="prose prose-lg max-w-none">
      <p>
        I'm Roger. I build things with code, ship them fast, and write about what I learn along the way.
      </p>
      <p>
        I run <a href={SOCIAL.axislabs} target="_blank" rel="noopener noreferrer">Axislabs</a>,
        a portfolio of AI-powered SaaS products. I'm also CTO & co-founder of
        <strong>Thoroughbreds.ai</strong>, where we're bringing AI to the thoroughbred racing industry.
      </p>
      <p>
        My background is full-stack engineering: Next.js, TypeScript, Python, and whatever else gets the job done.
        These days I spend most of my time at the intersection of AI and product development. I'm interested in
        what happens when you treat AI agents as first-class team members, not just tools.
      </p>
      <p>
        I'm based in Australia. When I'm not coding, I'm probably thinking about coding. Working on it.
      </p>
      <h2>What I write about</h2>
      <ul>
        <li>Building AI-powered products (the real stuff, not the hype)</li>
        <li>Shipping SaaS as a solo/small-team founder</li>
        <li>Engineering decisions and trade-offs</li>
        <li>The founder journey, unfiltered</li>
      </ul>
      <h2>Say hi</h2>
      <p>
        Find me on <a href={SOCIAL.twitter} target="_blank" rel="noopener noreferrer">X</a> or
        check out what I'm building on <a href={SOCIAL.github} target="_blank" rel="noopener noreferrer">GitHub</a>.
        Always happy to chat with other builders.
      </p>
    </div>
  </section>
</BaseLayout>
