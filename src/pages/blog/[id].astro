---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AuthorBio from "../../components/AuthorBio.astro";
import BlogPostFooter from "../../components/BlogPostFooter.astro";
import { getCollection, render } from "astro:content";
import { getReadingTime } from "../../utils/readingTime";
import { SITE_URL, AUTHOR, SOCIAL_PROFILES } from "../../consts";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  // Sort by date descending (newest first)
  const sorted = posts.sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
  );

  return sorted.map((post, i) => ({
    params: { id: post.id },
    props: {
      post,
      prevPost: i < sorted.length - 1 ? { id: sorted[i + 1].id, title: sorted[i + 1].data.title } : null,
      nextPost: i > 0 ? { id: sorted[i - 1].id, title: sorted[i - 1].data.title } : null,
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);

const readingTime = getReadingTime(post.body ?? "");
const wordCount = (post.body ?? "").split(/\s+/).filter(Boolean).length;
const formattedDate = post.data.pubDate.toLocaleDateString("en-AU", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "url": `${SITE_URL}/blog/${post.id}`,
  "image": `${SITE_URL}/og/${post.id}.png`,
  "datePublished": post.data.pubDate.toISOString(),
  "wordCount": wordCount,
  "articleSection": post.data.tags?.[0] ?? "Technology",
  "keywords": post.data.tags?.join(", "),
  "author": {
    "@type": "Person",
    "name": AUTHOR.name,
    "url": `${SITE_URL}/about`,
    "jobTitle": AUTHOR.jobTitle,
    "description": AUTHOR.bio,
    "image": `${SITE_URL}${AUTHOR.photo}`,
    "worksFor": {
      "@type": "Organization",
      ...AUTHOR.organization,
    },
    "sameAs": [...SOCIAL_PROFILES],
  },
  "publisher": {
    "@type": "Person",
    "name": AUTHOR.name,
    "url": SITE_URL,
    "image": `${SITE_URL}${AUTHOR.photo}`,
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `${SITE_URL}/blog/${post.id}`,
  },
};
---

<BaseLayout title={post.data.title} description={post.data.description} ogImage={`/og/${post.id}.png`} article pubDate={post.data.pubDate} jsonLd={articleSchema}>
  <article class="py-8">
    <header class="mb-10">
      <div class="flex items-center gap-3 text-sm text-[var(--color-text-muted)] mb-4">
        <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
        <span class="text-[var(--color-surface-overlay)]">&middot;</span>
        <span>{readingTime}</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">
        {post.data.title}
      </h1>
      <p class="text-lg text-[var(--color-text-secondary)]">
        {post.data.description}
      </p>
      <img
        src={`/og/${post.id}.png`}
        alt={post.data.title}
        class="mt-6 w-full rounded-lg border border-[var(--color-border)]"
        loading="eager"
      />
    </header>
    <div class="prose prose-lg max-w-none">
      <Content />
    </div>
  </article>

  <AuthorBio />

  <BlogPostFooter
    title={post.data.title}
    tags={post.data.tags}
    slug={post.id}
    prevPost={prevPost}
    nextPost={nextPost}
  />
</BaseLayout>
